---
import MainLayout from '~/components/layout/MainLayout.astro';
import Section from '~/components/ui/Section.astro';
import CtaBand from '~/components/sections/CtaBand.astro';
import ServiceAreaMap from '~/components/map/ServiceAreaMap.astro';
import { serviceAreaContent } from '~/content/service-area';
---

<MainLayout
  title={serviceAreaContent.pageTitle}
  description={serviceAreaContent.pageDescription}
>
  <Section spacing="lg" tone="canvas">
    <div class="max-w-2xl">
      <p class="eyebrow mb-3">Where we visit</p>
      <h1 class="text-4xl md:text-5xl font-medium leading-[1.1]">
        {serviceAreaContent.pageTitle}
      </h1>
      <p class="mt-6 text-lg text-cream/85 leading-relaxed">
        {serviceAreaContent.intro}
      </p>
    </div>
  </Section>

  <Section spacing="md" tone="canvas">
    <div class="grid gap-10 lg:grid-cols-[1fr_1.2fr] lg:items-start">
      <div>
        <h2 class="text-2xl font-medium text-cream">Areas typically covered</h2>
        <ul class="mt-5 grid gap-2 grid-cols-2 sm:grid-cols-1">
          {serviceAreaContent.areas.map((area) => (
            <li class="flex items-center gap-2.5 text-cream/85">
              <svg
                aria-hidden="true"
                class="h-4 w-4 text-accent flex-shrink-0"
                viewBox="0 0 20 20"
                fill="currentColor"
              >
                <path d="M10 2a6 6 0 0 0-6 6c0 4.5 6 10 6 10s6-5.5 6-10a6 6 0 0 0-6-6Zm0 8a2 2 0 1 1 0-4 2 2 0 0 1 0 4Z" />
              </svg>
              <span>{area}</span>
            </li>
          ))}
        </ul>

        <div class="mt-8 rounded-2xl bg-card border border-border-muted/40 p-5 shadow-soft">
          <h3 class="text-base font-medium text-cream">Good to know</h3>
          <ul class="mt-3 space-y-2 text-sm">
            {serviceAreaContent.notes.map((note) => (
              <li class="flex items-start gap-2 text-cream/80">
                <span
                  class="mt-1.5 h-1.5 w-1.5 rounded-full bg-accent flex-shrink-0"
                  aria-hidden="true"
                ></span>
                <span>{note}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <div>
        <ServiceAreaMap />
        <p class="mt-3 text-xs text-cream/60 leading-relaxed">
          The map shows an approximate service area for visual reference. The exact area, travel charges and availability are confirmed when arranging a booking. No home address is shown.
        </p>
      </div>
    </div>
  </Section>

  <CtaBand
    title="Not sure if you are in the area?"
    body="If your area is not listed, please ask. Coverage can sometimes flex for the right booking."
    primaryHref="/contact/"
    primaryLabel="Ask about availability"
  />
</MainLayout>
