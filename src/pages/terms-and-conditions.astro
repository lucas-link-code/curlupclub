---
import MainLayout from '~/components/layout/MainLayout.astro';
import Section from '~/components/ui/Section.astro';
import LegalPage from '~/components/sections/LegalPage.astro';
import { legalContent } from '~/content/legal';

const { termsAndConditions } = legalContent;
---

<MainLayout
  title={termsAndConditions.title}
  description="Terms and Conditions for Curl Up Club Cat Sitting."
>
  <Section spacing="lg" tone="canvas">
    <LegalPage
      title={termsAndConditions.title}
      intro={termsAndConditions.intro}
      lastUpdated={termsAndConditions.lastUpdated}
      sections={termsAndConditions.sections}
    />
  </Section>
</MainLayout>
