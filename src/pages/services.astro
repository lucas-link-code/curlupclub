---
import MainLayout from '~/components/layout/MainLayout.astro';
import Section from '~/components/ui/Section.astro';
import CtaBand from '~/components/sections/CtaBand.astro';
import { servicesContent } from '~/content/services';
import { servicesJsonLd, breadcrumbJsonLd } from '~/lib/jsonld';

const servicesPageJsonLd = [
  servicesJsonLd(),
  breadcrumbJsonLd([
    { name: 'Home', href: '/' },
    { name: servicesContent.pageTitle, href: '/services/' },
  ]),
];
---

<MainLayout
  title={servicesContent.pageTitle}
  description={servicesContent.pageDescription}
  jsonLd={servicesPageJsonLd}
>
  <Section spacing="lg" tone="canvas">
    <div class="max-w-2xl">
      <p class="eyebrow mb-3">What is included</p>
      <h1 class="text-4xl md:text-5xl font-medium leading-[1.1]">
        {servicesContent.pageTitle}
      </h1>
      <p class="mt-6 text-lg text-cream/85 leading-relaxed">
        {servicesContent.intro}
      </p>
    </div>
  </Section>

  <Section spacing="md" tone="canvas">
    <div class="grid gap-6 md:grid-cols-2">
      {servicesContent.services.map((service) => (
        <article class="rounded-3xl bg-card border border-border-muted/40 p-7 md:p-8 shadow-soft h-full">
          <h2 class="text-2xl font-medium text-cream">{service.title}</h2>
          <p class="mt-3 text-cream/80 leading-relaxed">{service.description}</p>
          <ul class="mt-5 space-y-2.5">
            {service.includes.map((item) => (
              <li class="flex items-start gap-2.5 text-sm">
                <svg
                  aria-hidden="true"
                  class="mt-0.5 h-4 w-4 text-accent flex-shrink-0"
                  viewBox="0 0 20 20"
                  fill="currentColor"
                >
                  <path d="M16.7 5.3a1 1 0 0 1 0 1.4l-7 7a1 1 0 0 1-1.4 0l-3-3a1 1 0 1 1 1.4-1.4L9 11.6l6.3-6.3a1 1 0 0 1 1.4 0Z" />
                </svg>
                <span class="text-cream/85">{item}</span>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </Section>

  <Section spacing="lg" tone="soft">
    <div class="grid gap-10 lg:grid-cols-[1.1fr_1fr] lg:items-center">
      <div class="relative aspect-[4/5] md:aspect-[5/6] rounded-3xl overflow-hidden ring-1 ring-border-muted/40 shadow-lift bg-canvas-deep">
        <img
          src="/images/cards/daily-updates.png"
          alt="Three cats on a cat tree at home, alongside a list of what may appear in a daily update"
          width="940"
          height="788"
          class="h-full w-full object-cover"
          loading="lazy"
          decoding="async"
        />
      </div>

      <div>
        <p class="eyebrow mb-2">{servicesContent.dailyUpdates.eyebrow}</p>
        <h2 class="text-3xl md:text-4xl font-medium leading-tight">
          {servicesContent.dailyUpdates.title}
        </h2>
        <p class="mt-5 text-cream/85 leading-relaxed">
          {servicesContent.dailyUpdates.intro}
        </p>
        <ul class="mt-6 space-y-2.5">
          {servicesContent.dailyUpdates.points.map((point) => (
            <li class="flex items-start gap-2.5 text-sm">
              <span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-accent flex-shrink-0" aria-hidden="true"></span>
              <span class="text-cream/85">{point}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </Section>

  <CtaBand
    eyebrow="Next step"
    title="Ready to talk about your cats?"
    body="Send a short enquiry with your dates and the basics. Leah will reply personally to talk through care and availability."
    primaryHref="/contact/"
    primaryLabel="Request cat care"
    secondaryHref="/pricing/"
    secondaryLabel="See pricing"
  />
</MainLayout>
