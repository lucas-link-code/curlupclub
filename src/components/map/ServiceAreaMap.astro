---
import { serviceAreaContent } from '~/content/service-area';

const { center, radiusMiles, zoom } = serviceAreaContent.map;
---

<div
  id="service-area-map"
  class="aspect-[4/3] md:aspect-[16/10] rounded-3xl overflow-hidden ring-1 ring-border-muted/40 shadow-lift bg-canvas-deep"
  data-lat={center.lat}
  data-lng={center.lng}
  data-radius-miles={radiusMiles}
  data-zoom={zoom}
  role="img"
  aria-label={`Approximate service area covering the Dee Valley and Wrexham County Borough, including Llangollen, Chirk, Ruabon, Wrexham and Gobowen, roughly ${radiusMiles} miles across. No home address is shown.`}
></div>

<link
  rel="stylesheet"
  href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
  integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
  crossorigin=""
/>

<script>
  import L from 'leaflet';

  const el = document.getElementById('service-area-map');
  if (el && el instanceof HTMLElement) {
    const lat = parseFloat(el.dataset.lat ?? '0');
    const lng = parseFloat(el.dataset.lng ?? '0');
    const radiusMiles = parseFloat(el.dataset.radiusMiles ?? '10');
    const zoom = parseInt(el.dataset.zoom ?? '10', 10);
    const radiusMeters = radiusMiles * 1609.344;

    const map = L.map(el, {
      center: [lat, lng],
      zoom,
      scrollWheelZoom: false,
      zoomControl: true,
      attributionControl: true,
    });

    L.tileLayer(
      'https://tile.openstreetmap.org/{z}/{x}/{y}.png',
      {
        maxZoom: 18,
        attribution:
          '&copy; <a href="https://www.openstreetmap.org/copyright" target="_blank" rel="noopener">OpenStreetMap</a> contributors',
      },
    ).addTo(map);

    L.circle([lat, lng], {
      radius: radiusMeters,
      color: '#e9b07a',
      weight: 2,
      fillColor: '#e9b07a',
      fillOpacity: 0.18,
    }).addTo(map);

    map.on('click', () => {
      map.scrollWheelZoom.enable();
    });
  }
</script>

<style is:global>
  /* Tweak Leaflet UI to match the site theme */
  .leaflet-container {
    background: var(--color-canvas-deep);
    font-family: var(--font-sans);
  }
  .leaflet-control-attribution {
    background: rgba(40, 48, 38, 0.75) !important;
    color: var(--color-cream) !important;
    font-size: 11px !important;
  }
  .leaflet-control-attribution a {
    color: var(--color-accent) !important;
  }
  .leaflet-bar a {
    background-color: var(--color-canvas) !important;
    color: var(--color-cream) !important;
    border-color: var(--color-border-muted) !important;
  }
  .leaflet-bar a:hover {
    background-color: var(--color-canvas-soft) !important;
  }
</style>
