---
interface Props {
  id?: string;
  tone?: 'canvas' | 'soft' | 'deep';
  spacing?: 'sm' | 'md' | 'lg';
  class?: string;
}

const {
  id,
  tone = 'canvas',
  spacing = 'md',
  class: classProp = '',
} = Astro.props;

const toneMap = {
  canvas: 'bg-canvas',
  soft: 'bg-canvas-soft',
  deep: 'bg-canvas-deep',
};

const spacingMap = {
  sm: 'py-12 md:py-16',
  md: 'py-16 md:py-24',
  lg: 'py-20 md:py-32',
};
---

<section id={id} class={`${toneMap[tone]} ${spacingMap[spacing]} ${classProp}`}>
  <div class="container-page">
    <slot />
  </div>
</section>
