---
import { mainNavigation } from '~/config/navigation';
import { siteConfig } from '~/config/site';

const currentPath = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath.startsWith(href);
---

<header class="sticky top-0 z-50 backdrop-blur-md bg-canvas/85 border-b border-border-muted/30">
  <div class="container-page flex items-center justify-between h-18 py-3">
    <a
      href="/"
      class="flex items-center gap-3 group"
      aria-label={`${siteConfig.siteName} home`}
    >
      <span class="inline-flex h-11 w-11 rounded-full overflow-hidden ring-1 ring-border-muted/40 bg-canvas-deep">
        <img
          src="/images/brand/curl-up-club-logo.png"
          alt=""
          width="44"
          height="44"
          class="h-full w-full object-cover"
          loading="eager"
          decoding="async"
        />
      </span>
      <span class="hidden sm:flex flex-col leading-tight">
        <span class="font-serif text-lg text-cream">Curl Up Club</span>
        <span class="eyebrow text-xs">Cat Sitting in and around the Dee Valley</span>
      </span>
    </a>

    <nav aria-label="Primary" class="hidden lg:block">
      <ul class="flex items-center gap-1">
        {mainNavigation.map((item) => (
          <li>
            <a
              href={item.href}
              class={`px-3 py-2 rounded-full text-sm transition-colors ${
                isActive(item.href)
                  ? 'text-accent'
                  : 'text-cream/85 hover:text-accent'
              }`}
              aria-current={isActive(item.href) ? 'page' : undefined}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="hidden lg:block">
      <a
        href="/contact/"
        class="inline-flex items-center justify-center gap-2 rounded-full bg-accent text-ink px-5 py-2.5 text-sm font-medium hover:bg-accent-soft transition-all duration-200 shadow-soft hover:-translate-y-0.5"
      >
        Request cat care
      </a>
    </div>

    <button
      type="button"
      id="mobile-menu-toggle"
      class="lg:hidden inline-flex items-center justify-center rounded-full p-2 text-cream hover:bg-canvas-soft transition-colors"
      aria-label="Open navigation menu"
      aria-controls="mobile-menu"
      aria-expanded="false"
    >
      <svg
        aria-hidden="true"
        class="h-6 w-6"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
      >
        <path d="M4 7h16M4 12h16M4 17h16" />
      </svg>
    </button>
  </div>

  <div
    id="mobile-menu"
    class="lg:hidden hidden border-t border-border-muted/30 bg-canvas"
  >
    <nav aria-label="Mobile" class="container-page py-4">
      <ul class="flex flex-col gap-1">
        {mainNavigation.map((item) => (
          <li>
            <a
              href={item.href}
              class={`block px-3 py-3 rounded-xl text-base ${
                isActive(item.href)
                  ? 'text-accent bg-canvas-soft'
                  : 'text-cream hover:bg-canvas-soft'
              }`}
              aria-current={isActive(item.href) ? 'page' : undefined}
            >
              {item.label}
            </a>
          </li>
        ))}
        <li class="pt-2">
          <a
            href="/contact/"
            class="block text-center w-full rounded-full bg-accent text-ink px-5 py-3 text-base font-medium"
          >
            Request cat care
          </a>
        </li>
      </ul>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const open = menu.classList.toggle('hidden') === false;
      toggle.setAttribute('aria-expanded', String(open));
      toggle.setAttribute(
        'aria-label',
        open ? 'Close navigation menu' : 'Open navigation menu',
      );
    });
  }
</script>
