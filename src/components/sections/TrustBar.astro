---
import { homepageContent } from '~/content/homepage';
const { trustBar } = homepageContent;
---

<div class="bg-canvas-deep border-y border-border-muted/30">
  <div class="container-page py-4 md:py-5">
    <ul
      class="grid grid-cols-2 gap-x-5 gap-y-2.5 text-sm text-cream/75 sm:flex sm:flex-wrap sm:items-center sm:justify-center sm:gap-x-8 sm:gap-y-2"
    >
      {trustBar.map((item) => (
        <li class="flex items-start gap-2 sm:items-center sm:gap-3">
          <svg
            aria-hidden="true"
            class="mt-0.5 h-4 w-4 text-accent flex-shrink-0 sm:mt-0"
            viewBox="0 0 20 20"
            fill="currentColor"
          >
            <path d="M10 1.6a8.4 8.4 0 1 0 0 16.8 8.4 8.4 0 0 0 0-16.8Zm-1.1 12L5.3 10 6.7 8.6l2.2 2.2 4.4-4.4 1.4 1.4-5.8 5.8Z" />
          </svg>
          <span class="leading-snug">{item}</span>
        </li>
      ))}
    </ul>
  </div>
</div>
