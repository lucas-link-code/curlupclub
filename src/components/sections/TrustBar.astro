---
import { homepageContent } from '~/content/homepage';
const { trustBar } = homepageContent;
---

<div class="bg-canvas-deep border-y border-border-muted/30">
  <div class="container-page py-5">
    <ul class="flex flex-wrap items-center justify-center gap-x-8 gap-y-2 text-sm text-cream/75">
      {trustBar.map((item) => (
        <li class="flex items-center gap-3">
          <svg
            aria-hidden="true"
            class="h-4 w-4 text-accent flex-shrink-0"
            viewBox="0 0 20 20"
            fill="currentColor"
          >
            <path d="M10 1.6a8.4 8.4 0 1 0 0 16.8 8.4 8.4 0 0 0 0-16.8Zm-1.1 12L5.3 10 6.7 8.6l2.2 2.2 4.4-4.4 1.4 1.4-5.8 5.8Z" />
          </svg>
          <span>{item}</span>
        </li>
      ))}
    </ul>
  </div>
</div>
