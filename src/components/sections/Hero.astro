---
import Button from '~/components/ui/Button.astro';
import { homepageContent } from '~/content/homepage';

const { hero } = homepageContent;
---

<section class="relative overflow-hidden bg-canvas">
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute -top-20 -right-20 h-96 w-96 rounded-full bg-accent/10 blur-3xl"></div>
    <div class="absolute -bottom-32 -left-20 h-96 w-96 rounded-full bg-gold/8 blur-3xl"></div>
  </div>

  <div class="container-page relative pt-8 pb-12 md:pt-24 md:pb-32">
    <div class="grid gap-8 md:gap-10 lg:gap-12 lg:grid-cols-2 lg:items-center">
      <div class="max-w-xl">
        <p class="eyebrow mb-2">{hero.eyebrow}</p>
        <h1 class="h-fluid-display font-medium">
          {hero.title}
        </h1>
        <p class="mt-4 text-base md:mt-6 md:text-lg lg:text-xl text-cream/85 leading-relaxed">
          {hero.description}
        </p>
        <div class="mt-6 md:mt-9 flex flex-wrap gap-3">
          <Button
            href={hero.primaryCta.href}
            variant="primary"
            size="lg"
            class="px-6 py-3 text-base md:px-8 md:py-4 md:text-lg"
          >
            {hero.primaryCta.label}
          </Button>
          <Button
            href={hero.secondaryCta.href}
            variant="secondary"
            size="lg"
            class="px-6 py-3 text-base md:px-8 md:py-4 md:text-lg"
          >
            {hero.secondaryCta.label}
          </Button>
        </div>
      </div>

      <div class="relative">
        <div class="relative mx-auto max-w-[14rem] sm:max-w-xs md:max-w-sm lg:max-w-none">
          <div class="absolute -inset-4 rounded-full bg-accent/15 blur-2xl" aria-hidden="true"></div>
          <div class="relative aspect-square rounded-full overflow-hidden ring-1 ring-border-muted/50 shadow-lift bg-canvas-deep">
            <img
              src="/images/brand/curl-up-club-logo.png"
              alt="Curl Up Club logo, an illustrated sleeping cat with the words Curl Up Club Cat Sitting"
              width="640"
              height="640"
              class="h-full w-full object-cover"
              loading="eager"
              decoding="async"
              fetchpriority="high"
            />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
