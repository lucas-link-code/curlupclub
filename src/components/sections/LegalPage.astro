---
interface Section {
  title: string;
  body: readonly string[];
}

interface Props {
  title: string;
  intro: string;
  lastUpdated: string;
  sections: readonly Section[];
}

const { title, intro, lastUpdated, sections } = Astro.props;
---

<article class="max-w-3xl mx-auto">
  <p class="eyebrow mb-3">Legal</p>
  <h1 class="text-4xl md:text-5xl font-medium leading-[1.1]">{title}</h1>
  <p class="mt-4 text-sm text-cream/60">Last updated: {lastUpdated}</p>
  <p class="mt-6 text-lg text-cream/85 leading-relaxed">{intro}</p>

  <div class="mt-12 space-y-10">
    {sections.map((section) => (
      <section>
        <h2 class="text-xl md:text-2xl font-medium text-cream border-b border-border-muted/40 pb-2">
          {section.title}
        </h2>
        <div class="mt-4 space-y-3 prose-cream">
          {section.body.map((paragraph) => (
            <p class="text-cream/85 leading-relaxed">{paragraph}</p>
          ))}
        </div>
      </section>
    ))}
  </div>
</article>
