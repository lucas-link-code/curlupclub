---
import Section from '~/components/ui/Section.astro';
import Button from '~/components/ui/Button.astro';
import { serviceAreaContent } from '~/content/service-area';
---

<Section spacing="lg" tone="soft">
  <div class="grid gap-10 lg:grid-cols-2 lg:items-center">
    <div class="max-w-xl">
      <p class="eyebrow mb-2">Where we visit</p>
      <h2 class="text-3xl md:text-4xl font-medium">
        Local, in-home cat care across the Dee Valley
      </h2>
      <p class="mt-5 text-cream/85 leading-relaxed">
        {serviceAreaContent.intro}
      </p>
      <ul class="mt-6 flex flex-wrap gap-2">
        {serviceAreaContent.areas.map((area) => (
          <li class="px-3 py-1.5 rounded-full bg-canvas border border-border-muted/40 text-sm text-cream/85">
            {area}
          </li>
        ))}
      </ul>
      <div class="mt-8">
        <Button href="/service-area/" variant="secondary">View service area</Button>
      </div>
    </div>

    <div class="relative aspect-[4/3] rounded-3xl overflow-hidden ring-1 ring-border-muted/40 shadow-lift bg-canvas-deep">
      <div class="absolute inset-0 grid place-items-center">
        <svg
          aria-hidden="true"
          class="h-32 w-32 text-cream/30"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
        >
          <path d="M12 2C7.6 2 4 5.6 4 10c0 5.5 8 12 8 12s8-6.5 8-12c0-4.4-3.6-8-8-8Z" />
          <circle cx="12" cy="10" r="3" />
        </svg>
      </div>
      <div class="absolute bottom-4 left-4 right-4 rounded-2xl bg-canvas/90 border border-border-muted/40 p-4 backdrop-blur-sm">
        <p class="text-xs text-cream/85">
          The full map shows an approximate service area only. No home address is shown.
        </p>
      </div>
    </div>
  </div>
</Section>
