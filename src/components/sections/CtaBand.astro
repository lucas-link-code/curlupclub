---
import Button from '~/components/ui/Button.astro';

interface Props {
  eyebrow?: string;
  title: string;
  body?: string;
  primaryHref?: string;
  primaryLabel?: string;
  secondaryHref?: string;
  secondaryLabel?: string;
}

const {
  eyebrow,
  title,
  body,
  primaryHref = '/contact/',
  primaryLabel = 'Request cat care',
  secondaryHref,
  secondaryLabel,
} = Astro.props;
---

<section class="bg-canvas-deep">
  <div class="container-page py-10 md:py-24">
    <div class="rounded-3xl bg-canvas-soft border border-border-muted/40 p-6 md:p-14 text-center shadow-soft">
      {eyebrow && <p class="eyebrow mb-2 md:mb-3">{eyebrow}</p>}
      <h2 class="h-fluid-section font-medium max-w-2xl mx-auto">{title}</h2>
      {body && (
        <p class="mt-3 md:mt-4 text-cream/80 max-w-xl mx-auto leading-relaxed">{body}</p>
      )}
      <div class="mt-6 md:mt-8 flex flex-wrap justify-center gap-3">
        <Button
          href={primaryHref}
          variant="primary"
          size="lg"
          class="px-6 py-3 text-base md:px-8 md:py-4 md:text-lg"
        >
          {primaryLabel}
        </Button>
        {secondaryHref && secondaryLabel && (
          <Button
            href={secondaryHref}
            variant="secondary"
            size="lg"
            class="px-6 py-3 text-base md:px-8 md:py-4 md:text-lg"
          >
            {secondaryLabel}
          </Button>
        )}
      </div>
    </div>
  </div>
</section>
